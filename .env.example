APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=sqlite:///./rss_reader.db
RSS_CONFIG_PATH=config/rss_config.yaml
FETCH_CRON="*/30 * * * *"
DAILY_SUMMARY_CRON="30 8 * * *"
DIGEST_OUTPUT_DIR=data/digests

LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
EMAIL_FROM=
EMAIL_TO=
SERVER_BASE_URL=http://127.0.0.1:8000

# For building docker image
IMAGE_REPO=registry.example.com/namespace/ai-rss-reader
IMAGE_TAG=<custom-tag>
PUSH_LATEST=true|false
DOCKERFILE=Dockerfile
CONTEXT=.
